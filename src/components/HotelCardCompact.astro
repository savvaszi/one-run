---
import { displayChars } from '../lib/display';

const { hotel, bookable } = Astro.props;
const starsHtml = Array.from({ length: hotel.stars }, () => '<span class="star">&#9733;</span>').join('');
const featuresHtml = displayChars(features) + ' &middot; from &euro;' + (singlePackage?.price || 0).toLocaleString();
const activePackages = (hotel.packages || []).filter((pkg: any) => pkg.active);
const singlePackage = activePackages.find((pkg: any) => pkg.type === 'single');
const seatsLeft = activePackages.reduce((lowest: number, pkg: any) => Math.min(lowest, pkg.total_seats - pkg.booked_seats), Number.POSITIVE_INFINITY);
const soldOut = seatsLeft <= 0;
---

<article class={`hotel-card-compact${soldOut || !bookable ? '' : ''}`} data-hotel-id={hotel.id}>
  {hotel.website && <a href={hotel.website} target="_blank" rel="noopener noreferrer" class="hc-website-link" onclick="event.stopPropagation()">Visit &#8599;</a>}
  <div class="hc-photo"><span>{hotel.name}</span></div>
  <div class="hc-content">
    <div class="hc-name-row">
      <span class="hc-name">{hotel.name}</span>
      <span class="hc-stars" set:html={starsHtml}></span>
    </div>
    <div class="hc-area" set:html={displayChars(hotel.area)}></div>
    <div class="hc-features" set:html={featuresHtml}></div>
    {soldOut && <div style="color:var(--red);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;margin-top:4px;">Sold out</div>}
    {!soldOut && <div style="color:var(--mute);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;margin-top:4px;">{seatsLeft} seat{seatsLeft !== 1 ? 's' : ''} left</div>}
  </div>
</article>
