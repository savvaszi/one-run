---
import Base from '../../layouts/Base.astro';
import AdminNav from '../../components/AdminNav.astro';
import { db } from '../../db/index';
import { races as racesTable } from '../../db/schema';
import { isAdmin } from '../../lib/auth';

export const prerender = false;
if (!isAdmin(Astro.cookies)) return Astro.redirect('/admin/login');

const allRaces = await db.select().from(racesTable).all();
---

<Base title="Manage Races — Admin — One Run">
  <AdminNav />
  <section style="padding:120px 48px 80px;max-width:1100px;margin:0 auto;">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:32px;">
      <div>
        <div class="section-tag">Admin</div>
        <h2 class="section-title">Manage <em>races</em></h2>
      </div>
      <button onclick="showAddForm()" class="btn-primary" style="padding:12px 24px;font-size:11px;">+ Add race</button>
    </div>

    <div id="addRaceForm" style="display:none;background:var(--card);border:1px solid var(--border);padding:28px;margin-bottom:32px;">
      <h3 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:500;margin-bottom:20px;">Add New Race</h3>
      <form id="raceForm" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div class="form-group"><label class="form-label">ID (slug)</label><input class="form-input" name="id" required /></div>
        <div class="form-group"><label class="form-label">Name</label><input class="form-input" name="name" required /></div>
        <div class="form-group"><label class="form-label">City</label><input class="form-input" name="city" required placeholder="City, Country" /></div>
        <div class="form-group"><label class="form-label">Icon</label><input class="form-input" name="icon" required placeholder="berlin, athens, etc." /></div>
        <div class="form-group"><label class="form-label">Date</label><input class="form-input" name="date" required placeholder="27 Sep 2026" /></div>
        <div class="form-group"><label class="form-label">Month (1-12)</label><input class="form-input" name="month" type="number" required /></div>
        <div class="form-group"><label class="form-label">Price from</label><input class="form-input" name="price_from" required placeholder="€1,290" /></div>
        <div class="form-group"><label class="form-label">Terrain</label>
          <select class="form-input" name="terrain" required style="background:transparent;color:var(--fg);border:1px solid var(--border);padding:14px 16px;">
            <option value="Flat & fast">Flat &amp; fast</option><option value="Hilly">Hilly</option><option value="Urban">Urban</option>
          </select>
        </div>
        <div class="form-group"><label class="form-label">Status</label>
          <select class="form-input" name="status" required style="background:transparent;color:var(--fg);border:1px solid var(--border);padding:14px 16px;">
            <option value="open">Open</option><option value="express">Express</option><option value="soldout">Sold out</option>
          </select>
        </div>
        <div class="form-group" style="grid-column:span 2;"><label class="form-label">Description</label><textarea class="form-input form-textarea" name="desc1" rows="3" required></textarea></div>
        <button type="submit" class="form-submit" style="grid-column:span 2;">Create race</button>
      </form>
    </div>

    <div style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="border-bottom:1px solid var(--border);text-align:left;">
            <th style="padding:12px 8px;color:var(--mute);font-weight:400;">ID</th>
            <th style="padding:12px 8px;color:var(--mute);font-weight:400;">Name</th>
            <th style="padding:12px 8px;color:var(--mute);font-weight:400;">Date</th>
            <th style="padding:12px 8px;color:var(--mute);font-weight:400;">Status</th>
            <th style="padding:12px 8px;color:var(--mute);font-weight:400;">Price</th>
            <th style="padding:12px 8px;color:var(--mute);font-weight:400;">Actions</th>
          </tr>
        </thead>
        <tbody>
          {allRaces.map(r => (
            <tr style="border-bottom:1px solid rgba(243,239,232,0.04);">
              <td style="padding:10px 8px;color:var(--accent);">{r.id}</td>
              <td style="padding:10px 8px;color:var(--fg);">{r.name}</td>
              <td style="padding:10px 8px;color:var(--mute);">{r.date}</td>
              <td style="padding:10px 8px;color:var(--fg);">{r.status}</td>
              <td style="padding:10px 8px;color:var(--fg);">{r.price_from}</td>
              <td style="padding:10px 8px;">
                <a href={`/admin/races/${r.id}`} style="color:var(--accent);font-size:11px;letter-spacing:1px;text-transform:uppercase;">Edit</a>
                &nbsp;&nbsp;
                <button onclick={`deleteRace('${r.id}')`} style="color:var(--red);background:none;border:none;cursor:pointer;font-size:11px;letter-spacing:1px;text-transform:uppercase;">Delete</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Base>

<script>
  function showAddForm() {
    document.getElementById('addRaceForm')!.style.display = 'block';
  }
  document.getElementById('raceForm')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const data = Object.fromEntries(new FormData(form));
    data.month = parseInt(data.month as string);
    const res = await fetch('/api/admin/races', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    if (res.ok) { window.location.reload(); }
    else { alert('Failed to create race'); }
  });
  async function deleteRace(id: string) {
    if (!confirm('Delete this race?')) return;
    const res = await fetch(`/api/admin/races/${id}`, { method: 'DELETE' });
    if (res.ok) { window.location.reload(); }
    else { alert('Failed to delete'); }
  }
</script>
