---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import RaceGrid from '../components/RaceGrid.astro';
import Footer from '../components/Footer.astro';
import InterestModal from '../components/InterestModal.astro';
import { directusGetItems, type DirectusRace } from '../lib/directus';

export const prerender = false;

const racesData = await directusGetItems<DirectusRace>('races', { sort: 'sort', limit: -1 });
---

<Base title="One Run — Marathon Travel Experiences">
  <div id="homepage">
    <Nav />
    <section class="hero">
      <Hero />
      <div class="hero-runner">
        <video id="heroVideo" autoplay muted loop playsinline poster="/Runner.jpg">
          <source src="/video/hero.mp4" type="video/mp4" />
        </video>
      </div>
    </section>
    <RaceGrid races={racesData} />
    <Footer />
  </div>
  <InterestModal />
  <script id="races-data" type="application/json" set:html={JSON.stringify(racesData)}></script>
  <script>
    const video = document.getElementById('heroVideo');
    const hero = document.querySelector('.hero');
    if (video && hero) {
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const heroBottom = hero.offsetTop + hero.offsetHeight;
            const scrollPos = window.scrollY;
            const progress = Math.min(1, Math.max(0, scrollPos / (heroBottom - window.innerHeight * 0.3)));
            const scale = 1 + progress * 0.35;
            video.style.transform = `scale(${scale})`;
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    }
  </script>
</Base>
