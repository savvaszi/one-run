---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import RaceGrid from '../components/RaceGrid.astro';
import Footer from '../components/Footer.astro';
import InterestModal from '../components/InterestModal.astro';
import { directusGetItems, type DirectusRace } from '../lib/directus';

export const prerender = false;

const racesData = await directusGetItems<DirectusRace>('races', { sort: 'sort', limit: -1 });
---

<Base title="One Run — Marathon Travel Experiences">
  <div id="homepage">
    <Nav />
    <section class="hero">
      <Hero />
      <div class="hero-runner">
        <video id="heroVideo" muted playsinline preload="auto" poster="/Runner.jpg">
          <source src="/video/hero.mp4" type="video/mp4" />
        </video>
      </div>
    </section>
    <RaceGrid races={racesData} />
    <Footer />
  </div>
  <InterestModal />
  <script id="races-data" type="application/json" set:html={JSON.stringify(racesData)}></script>
  <script>
    const video = document.getElementById('heroVideo');
    const hero = document.querySelector('.hero');
    if (video && hero) {
      video.addEventListener('loadedmetadata', () => {
        video.pause();
        video.currentTime = 0;
      });

      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const heroTop = hero.getBoundingClientRect().top;
            const heroHeight = hero.offsetHeight;
            const viewHeight = window.innerHeight;
            const rangeStart = heroTop;
            const rangeEnd = heroTop + heroHeight - viewHeight * 0.2;
            const scrollDist = rangeEnd - rangeStart;
            if (scrollDist > 0) {
              const progress = Math.min(1, Math.max(0, -heroTop / scrollDist));
              if (video.duration) {
                video.currentTime = progress * video.duration;
              }
            }
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    }
  </script>
</Base>
