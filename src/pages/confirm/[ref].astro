---
import Base from '../../layouts/Base.astro';
import { directusGetItem, directusGetItems, type DirectusBooking, type DirectusHotel, type DirectusPackage, type DirectusRace } from '../../lib/directus';

export const prerender = false;

const { ref } = Astro.params;
const booking = (await directusGetItems<DirectusBooking>('bookings', { 'filter[reference][_eq]': ref!, limit: 1 }))[0];

if (!booking) return Astro.redirect('/');

const race = await directusGetItem<DirectusRace>('races', Number(booking.race));
const hotel = await directusGetItem<DirectusHotel>('hotels', Number(booking.hotel));
const selectedPackage = await directusGetItem<DirectusPackage>('packages', Number(booking.package));
const isPaid = booking.status === 'paid';
---

<Base title="Booking Confirmed — One Run Travel Packages">
  <div class="confirm-page active">
    <div class="confirm-content">
      <div class="confirm-icon">&check;</div>
      <h2 class="confirm-title">Thank <em>you</em>.</h2>
      <p class="confirm-text">{isPaid ? 'Your payment has been received and your booking is confirmed.' : `Your booking status is ${booking.status}.`}<br />{isPaid ? 'A confirmation email is on its way to your inbox.' : 'We will update this page when the payment status changes.'}</p>

      <div class="confirm-details">
        <div class="confirm-row"><span class="l">Race</span><span class="v">{race?.name || 'N/A'}</span></div>
        <div class="confirm-row">
          <span class="l">Package</span>
          <span class="v">{selectedPackage.label}<br /><span style="font-size:11px;color:var(--mute);">{hotel?.name || 'N/A'}</span></span>
        </div>
        <div class="confirm-row"><span class="l">Booking ref</span><span class="v">{booking.reference}</span></div>
        <div class="confirm-row total"><span class="l">Paid</span><span class="v">&euro;{booking.total_amount.toLocaleString()}</span></div>
      </div>

      <p class="confirm-next"><strong>Next steps:</strong> Within 2&ndash;4 business days you'll receive full registration details &mdash; race bib confirmation, hotel voucher, transfer instructions and a personal contact for your trip.</p>

      <a href="/" class="btn-primary" style="margin-top:32px;">Back to home</a>
    </div>
  </div>
</Base>
